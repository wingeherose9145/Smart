            android:text="1/x"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:background="@drawable/calculator_button_orange"/>

        <!-- 第8行 -->
        <Button
            android:id="@+id/btnSum"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="Σ"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/calculator_button_orange"/>

        <Button
            android:id="@+id/btnInt"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="∫"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/calculator_button_orange"/>

        <Button
            android:id="@+id/btnInf"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="∞"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/calculator_button_dark"/>

        <Button
            android:id="@+id/btnDel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="DEL"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:background="@drawable/calculator_button_orange"/>

        <!-- 第9行 -->
        <Button
            android:id="@+id/btnKg"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="kg"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:background="@drawable/calculator_button_dark"/>

        <Button
            android:id="@+id/btnMol"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="mol"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:background="@drawable/calculator_button_dark"/>

        <Button
            android:id="@+id/btnAmp"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="A"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:background="@drawable/calculator_button_dark"/>

        <Button
            android:id="@+id/btnKel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="K"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:background="@drawable/calculator_button_dark"/>

        <!-- 第10行 -->
        <Button
            android:id="@+id/btnHz"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="Hz"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:background="@drawable/calculator_button_dark"/>

        <Button
            android:id="@+id/btnOhm"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="Ω"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:background="@drawable/calculator_button_dark"/>

        <Button
            android:id="@+id/btnFar"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="F"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:background="@drawable/calculator_button_dark"/>

        <Button
            android:id="@+id/btnHen"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="H"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:background="@drawable/calculator_button_dark"/>

        <!-- 第11行 -->
        <Button
