            android:textSize="18sp"
            android:background="@drawable/calculator_button_dark"/>

        <Button
            android:id="@+id/btnMinus"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
