            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/calculator_button_orange"/>

        <!-- 第6行 -->
        <Button
            android:id="@+id/btn0"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
