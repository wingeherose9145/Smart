<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A0F08"
    android:padding="6dp">

    <!-- 显示屏 -->
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_display"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_marginBottom="6dp"
        android:background="#2A1408"
        android:gravity="center_vertical|end"
        android:padding="16dp"
        android:text="0"
        android:textColor="#FFB366"
        android:textSize="32sp"
        android:textStyle="bold"
        android:maxLines="1"
        app:autoSizeTextType="uniform"
        app:autoSizeMinTextSize="14sp"
        app:autoSizeMaxTextSize="36sp"
        app:autoSizeStepGranularity="2sp" />

    <!-- 按钮区域 -->
    <GridLayout
    android:id="@+id/grid_buttons"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:columnCount="4"
    android:rowCount="12"
    android:useDefaultMargins="true"/>

        <!-- 第1行 -->
        <Button
            android:id="@+id/btnSin"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="sin"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/calculator_button_orange"/>

        <Button
            android:id="@+id/btnCos"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="cos"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/calculator_button_orange"/>

        <Button
            android:id="@+id/btnTan"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="tan"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/calculator_button_orange"/>

        <Button
            android:id="@+id/btnPi"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="π"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/calculator_button_dark"/>

        <!-- 第2行 -->
        <Button
            android:id="@+id/btnLg"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="lg"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/calculator_button_orange"/>

        <Button
            android:id="@+id/btnLn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="ln"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/calculator_button_orange"/>

        <Button
            android:id="@+id/btnExp"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="eˣ"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/calculator_button_dark"/>

        <Button
            android:id="@+id/btnMod"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="%"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/calculator_button_dark"/>

<Button
    android:id="@+id/btnPow"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_columnWeight="1"
    android:text="x²"
    android:textSize="18sp"
    android:textColor="#FFFFFF"
    android:background="@drawable/calculator_button_orange"/>

<Button
    android:id="@+id/btnFact"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_columnWeight="1"
    android:text="!"
    android:textSize="18sp"
    android:textColor="#FFFFFF"
    android:background="@drawable/calculator_button_orange"/>
        

        <!-- 第3行 -->
        <Button
            android:id="@+id/btn7"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="7"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/calculator_button_dark"/>

        <Button
            android:id="@+id/btn8"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="8"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/calculator_button_dark"/>

        <Button
            android:id="@+id/btn9"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="9"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/calculator_button_dark"/>

        <Button
            android:id="@+id/btnDivide"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="÷"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/calculator_button_orange"/>

        <!-- 第4行 -->
        <Button
            android:id="@+id/btn4"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="4"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/calculator_button_dark"/>

        <Button
            android:id="@+id/btn5"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="5"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/calculator_button_dark"/>

        <Button
            android:id="@+id/btn6"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="6"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/calculator_button_dark"/>

        <Button
            android:id="@+id/btnMultiply"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="×"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/calculator_button_orange"/>

        <!-- 第5行 -->
        <Button
            android:id="@+id/btn1"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="1"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/calculator_button_dark"/>

        <Button
            android:id="@+id/btn2"
            android:layout_width="0dp"
